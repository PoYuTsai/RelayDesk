{
  "projects": [
    {
      "id": "my-app",
      "name": "My App",
      "path": "C:\\path\\to\\MyApp",
      "runners": [
        {
          "id": "claude-code",
          "name": "Claude Code tmux",
          "kind": "tmux",
          "session": "rc-my-app",
          "tmux": {
            "mode": "wsl",
            "cwd": "/mnt/c/path/to/MyApp",
            "terminalProfile": "Ubuntu",
            "startCommand": "bash -lc 'cd /mnt/c/path/to/MyApp && claude --model opus --effort xhigh'"
          }
        },
        {
          "id": "codex-cli",
          "name": "Codex CLI tmux",
          "kind": "tmux",
          "session": "rc-codex-my-app",
          "tmux": {
            "mode": "wsl",
            "cwd": "/mnt/c/path/to/MyApp",
            "terminalProfile": "Ubuntu",
            "startCommand": "bash -lc 'cd /mnt/c/path/to/MyApp && codex --model gpt-5.5 --no-alt-screen --dangerously-bypass-approvals-and-sandbox -C /mnt/c/path/to/MyApp'",
            "dismissCodexUpdatePrompt": true
          }
        }
      ]
    }
  ]
}
