{
  "name": "relaydesk",
  "version": "0.1.0",
  "private": true,
  "description": "Clean-room local agent workflow cockpit for native CLI agents and tmux runners.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "api": "node server/relay-server.mjs",
    "start": "node server/relay-server.mjs",
    "serve": "npm run build && node server/relay-server.mjs",
    "build": "tsc && vite build",
    "check:presets": "node scripts/check-agent-presets.mjs",
    "check:public": "node scripts/public-scan.mjs",
    "check:release": "node scripts/release-check.mjs",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "playwright-core": "^1.61.0"
  }
}
